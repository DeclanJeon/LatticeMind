#!/usr/bin/env bash
set -euo pipefail
MODE="${1:-}"
SLOT_STATE="${HOME}/.local/state/latticemind/slots.json"
SCHEDULED_AT=""
SLOT_ID=""
GRANT=""
shift || true
while (($#)); do
  case "$1" in
    --slot-state|--scheduled-at|--slot-id|--grant)
      [[ $# -ge 2 ]] || { printf 'Missing value for %s.\n' "$1" >&2; exit 64; }
      case "$1" in
        --slot-state) SLOT_STATE="$2" ;;
        --scheduled-at) SCHEDULED_AT="$2" ;;
        --slot-id) SLOT_ID="$2" ;;
        --grant) GRANT="$2" ;;
      esac
      shift 2 ;;
    *) printf 'Unknown scheduler argument: %s\n' "$1" >&2; exit 64 ;;
  esac
done
case "$MODE" in
  freshness|health) [[ -z "$GRANT" ]] || { printf 'Observe-only mode rejects write grants.\n' >&2; exit 73; } ;;
  morning|nightly|weekly)
    [[ "$GRANT" == "scheduled-write:$MODE" ]] || { printf 'Write job requires an explicit scheduled-write grant: %s\n' "$MODE" >&2; exit 73; } ;;
  *) printf 'Unknown maintenance mode.\n' >&2; exit 64 ;;
esac
# shellcheck disable=SC1007
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
CORE_ROOT="$SCRIPT_DIR"
[[ -d "$CORE_ROOT/latticemind_core" ]] || { printf 'Installed package root unavailable.\n' >&2; exit 69; }
[[ -r "$CORE_ROOT/latticemind_core/cli.py" ]] || { printf 'Installed package entry point unavailable.\n' >&2; exit 69; }
export LATTICEMIND_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/latticemind/config-v1.json"
[[ -r "$LATTICEMIND_CONFIG" ]] || { printf 'Canonical config-v1.json is required.\n' >&2; exit 78; }
mkdir -p "$(dirname "$SLOT_STATE")"
exec env PYTHONPATH="$CORE_ROOT" python3 - "$CORE_ROOT" "$SLOT_STATE" "$MODE" "$SCHEDULED_AT" "$SLOT_ID" <<'PY'
import fcntl
import os, subprocess, sys
from datetime import datetime, timezone
from latticemind_core.jobs import get_job, run_persisted_slot, scheduled_occurrence, slot_identity
_, package_root, slot_state, mode, scheduled_arg, slot_arg = sys.argv
lock = open(os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), f"latticemind-{os.getuid()}.lock"), "w")
try:
    fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
except BlockingIOError:
    print("maintenance lock contention", file=sys.stderr)
    raise SystemExit(75)
if not os.path.isdir(package_root):
    raise SystemExit("installed package root unavailable")
job = get_job(mode)
now = datetime.now(timezone.utc)
scheduled = datetime.fromisoformat(scheduled_arg) if scheduled_arg else scheduled_occurrence(job, datetime.now().astimezone())
if scheduled.tzinfo is None or scheduled.utcoffset() is None:
    raise SystemExit("scheduled occurrence must include timezone offset")
slot = slot_arg or slot_identity(job, scheduled.date())
if slot != slot_identity(job, scheduled.date()):
    raise SystemExit("slot id does not match scheduled occurrence")
def execute():
    command = ["freshness", "scan"] if job.mode == "freshness" else ["status"]
    return subprocess.call([sys.executable, "-m", "latticemind_core.cli", *command])
result = run_persisted_slot(slot_state, job, slot, execute, scheduled=scheduled, now=now)
print(result)
raise SystemExit({"succeeded": 0, "degraded": 2, "blocked": 69, "timed_out": 124, "expired": 0, "skipped": 0}.get(result, 78))
PY
